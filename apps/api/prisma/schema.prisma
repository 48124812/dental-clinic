// =============================================================================
// Dental Clinic Database Schema
// =============================================================================
// 對應講義：
// - NTU App Arch P.67 持久化層 / Repository
// - 12-Factor Factor 4 (P.28) Backing services as attached resources
// - Sprint 1 stories: US-01 (business hours), US-03 (doctors), US-04 (services)
//
// 修改後執行：
//   pnpm --filter @dental-clinic/api db:migrate  (建立 migration + 套用 + 重生 Prisma Client)
// =============================================================================

generator client {
  provider = "prisma-client-js"
  // 把產生的 Client 放在預設位置 node_modules/@prisma/client (符合 pnpm 期待)
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// Doctor — 醫師（US-03）
// -----------------------------------------------------------------------------
model Doctor {
  id            String    @id @default(cuid())
  // cuid = Collision-resistant Unique IDentifier
  // - URL-safe、長度比 UUID 短、按時間單調遞增（適合分頁）
  // - 比自動遞增 int 安全（不洩漏「我們有 N 個醫師」）

  name          String    // 王大明
  title         String    // 院長 / 主治醫師
  specialties   String[]  // Postgres native array：["一般牙科", "植牙"]
  bioMd         String    // Markdown 自介
  credentials   String[]  // 學歷／經歷／證照
  photoUrl      String?   // 可能還沒上傳，nullable
  displayOrder  Int       @default(0)  // 列表排序用
  active        Boolean   @default(true) // 退休/離職時設 false

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([active, displayOrder])  // 查詢時最常用：active doctors sorted by order
}

// -----------------------------------------------------------------------------
// Service — 療程／服務項目（US-04）
// -----------------------------------------------------------------------------
enum ServiceCategory {
  PREVENTIVE   // 預防：洗牙、檢查、塗氟
  RESTORATIVE  // 修復：補牙、根管、牙冠
  COSMETIC     // 美容：美白、貼片
  ORTHODONTIC  // 矯正：傳統、隱形
  SURGERY      // 外科：植牙、拔牙
  PEDIATRIC    // 兒童牙科
}

model Service {
  id             String          @id @default(cuid())
  name           String          // 「定期檢查與洗牙」
  category       ServiceCategory
  priceMin       Int             // 最低價（NTD）
  priceMax       Int?            // 最高價；null = 視評估
  isNhi          Boolean         @default(false)  // 是否健保給付
  descriptionMd  String          // Markdown 說明
  displayOrder   Int             @default(0)
  active         Boolean         @default(true)

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([active, category, displayOrder])
}

// -----------------------------------------------------------------------------
// BusinessHours — 營業時間（US-01）
// -----------------------------------------------------------------------------
// 一週 7 筆，每筆代表一天。MVP 不處理午休 / 特殊休診（明節日等），之後再加。
model BusinessHours {
  id         String   @id @default(cuid())
  dayOfWeek  Int      @unique  // 0=Sun, 1=Mon, ..., 6=Sat
  isClosed   Boolean  @default(false)
  openTime   String?  // "HH:MM"；isClosed=true 時為 null
  closeTime  String?  // "HH:MM"

  updatedAt  DateTime @updatedAt
}
