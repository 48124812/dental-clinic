# apps/api/.env — copy to .env (gitignored) and adjust.
#
# 對應講義：12-Factor Factor 3 (P.25) Config strictly separate from code.
# 注意：這份和 root 的 .env 內容可能重疊，但「不同層次」：
#   - 根目錄的 .env  → 給 docker-compose 讀，組合 postgres container 的環境變數
#   - 這份 apps/api/.env → 給 Node app 與 Prisma CLI 讀

# Database connection (Prisma + runtime app)
DATABASE_URL=postgresql://dental:devpassword_change_me@localhost:5432/dental?schema=public

# Application
PORT=3001
LOG_LEVEL=info
APP_VERSION=dev
