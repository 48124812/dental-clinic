# apps/api/.env — copy to .env (gitignored) and adjust.
#
# All env vars are validated by src/config.ts (Zod schema). If you set anything
# wrong, the app refuses to start and prints exactly what's invalid.
#
# 對應講義：12-Factor Factor 3 (P.25) Config strictly separate from code.

# ----- Database connection (REQUIRED) -----
# Used by Prisma CLI (migrate/generate/seed) and runtime PrismaClient.
DATABASE_URL=postgresql://dental:devpassword_change_me@localhost:5432/dental?schema=public

# ----- Server -----
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# ----- Logging -----
# One of: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ----- App metadata -----
# In CI/Docker we inject the git SHA so /health knows which version is live.
APP_VERSION=dev

# ----- CORS -----
# Comma-separated list of allowed origins (Fastify CORS plugin reads as array).
CORS_ORIGIN=http://localhost:3000
