# Auto-detect text files and normalize line endings to LF in repo
* text=auto eol=lf

# Explicit text files
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.sh        text eol=lf
Dockerfile  text eol=lf

# Force LF for shell scripts (must run on Linux containers)
*.sh        text eol=lf

# Binary files (do not diff or normalize)
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.pdf       binary
*.woff      binary
*.woff2     binary
