# =============================================================================
# Environment variables — copy this file to `.env` for local dev.
# =============================================================================
# `.env` is gitignored. `.env.example` is in git (no real secrets here).
# Docker Compose 自動讀取根目錄的 .env (variable interpolation in compose.yml).
#
# 對應講義：
# - 12-Factor Factor 3 (P.25): Config strictly separate from code
# - 12-Factor SDLC P.74: Config/secrets externalized (no secrets in git)
# =============================================================================

# ----- Postgres (used by docker-compose.yml) -----
POSTGRES_USER=dental
POSTGRES_PASSWORD=devpassword_change_me
POSTGRES_DB=dental

# ----- Application -----
# Prisma / API 連線字串 (Phase 3.5 開始用)
# 格式: postgresql://USER:PASS@HOST:PORT/DB?schema=SCHEMA
DATABASE_URL=postgresql://dental:devpassword_change_me@localhost:5432/dental?schema=public

# API server port (apps/api 會讀)
PORT=3001
LOG_LEVEL=info

# ----- Frontend -----
# Next.js 前端會打的 API base URL
NEXT_PUBLIC_API_URL=http://localhost:3001
